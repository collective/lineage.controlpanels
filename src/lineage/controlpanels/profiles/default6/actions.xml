<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Plone Actions Tool"
        name="portal_actions"
>
  <object meta_type="CMF Action Category"
          name="user"
          purge="False"
  >
    <object meta_type="CMF Action"
            name="plone_setup_subsite"
            i18n:domain="plone"
    >
      <property name="title" i18n:translate="">Site Setup</property>
      <property name="description" i18n:translate=""></property>
      <property name="icon_expr">string:plone-controlpanel</property>

      <property name="available_expr">python:plone_portal_state.navigation_root().restrictedTraverse('@@lineageutils').isChildSite()</property>
      <property name="url_expr">string:${plone_portal_state/navigation_root_url}/@@overview-controlpanel</property>
      <property name="permissions">
        <element value="Plone Site Setup: Overview"/>
      </property>
      <property name="visible">True</property>
    </object>

    <object meta_type="CMF Action"
            name="plone_setup"
            purge="False"
            i18n:domain="plone"
    >
      <property
          name="available_expr">not:python:plone_portal_state.navigation_root().restrictedTraverse(&#x27;@@lineageutils&#x27;).isChildSite()</property>
    </object>
  </object>
</object>
